---
export interface Props {
  title: string;
  description: string;
  lang?: string;
  path?: string;
}

const { title, description, lang = 'zh-CN', path = '/' } = Astro.props;
const isCn = lang.startsWith('zh');
const alternateLang = isCn ? 'en' : 'zh-cn';
const alternatePath = path === '/' 
  ? (isCn ? '/en/' : '/') 
  : (isCn ? `/en${path}` : path.replace('/en', ''));
const canonicalBase = 'https://humanaifit.com';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | humanaifit</title>
  <meta name="description" content={description} />

  <!-- Canonical -->
  <link rel="canonical" href={`${canonicalBase}${path}`} />

  <!-- Alternate hreflang -->
  <link rel="alternate" href={`${canonicalBase}${isCn ? '/' : '/en/'}`} hreflang="zh-CN" />
  <link rel="alternate" href={`${canonicalBase}${isCn ? '/en/' : '/'}`} hreflang="en" />
  <link rel="alternate" href={`${canonicalBase}/`} hreflang="x-default" />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | humanaifit`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`${canonicalBase}${path}`} />
  <meta property="og:locale" content={isCn ? 'zh_CN' : 'en_US'} />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Styles -->
  <link rel="stylesheet" href="/src/styles/global.css" />

  <!-- Scripts -->
  <script>
    // Language switch — works on any page, not just index
    // Only fires when lang-switch has no href (legacy fallback)
    document.addEventListener('DOMContentLoaded', () => {
      const langSwitch = document.querySelector('.lang-switch');
      if (langSwitch && !langSwitch.getAttribute('href')) {
        langSwitch.addEventListener('click', () => {
          const isCn = document.documentElement.lang === 'zh-CN';
          const path = window.location.pathname;
          let target;
          if (isCn) {
            if (path.startsWith('/blog/') && path !== '/blog/') {
              target = '/en/blog/';
            } else if (path === '/' || path === '') {
              target = '/en/';
            } else {
              target = '/en' + path;
            }
          } else {
            target = path.replace('/en', '') || '/';
          }
          window.location.href = target;
        });
      }
    });

    // Active nav highlighting
    document.addEventListener('DOMContentLoaded', () => {
      var path = window.location.pathname;
      var links = document.querySelectorAll('.nav-links a');
      links.forEach(function(a) {
        var href = a.getAttribute('href');
        // Skip buttons and external links
        if (a.classList.contains('btn') || a.classList.contains('btn-cbam') || a.classList.contains('lang-switch') || !href) return;
        // Exact match or starts-with match for deeper pages
        if (href === '/' && (path === '/' || path === '')) {
          a.style.color = '#C9A96E';
          a.style.fontWeight = '600';
        } else if (href !== '/' && path.startsWith(href) && href.length > 1) {
          a.style.color = '#C9A96E';
          a.style.fontWeight = '600';
        }
      });
    });
  </script>
</head>
<body>
  <!-- Header (v2: 毛玻璃效果 + 当前页面高亮) -->
  <header class="header" style="-webkit-backdrop-filter:blur(12px);backdrop-filter:blur(12px);background:rgba(255,255,255,0.85);">
    <nav class="nav">
      <a href={isCn ? '/' : '/en/'} class="nav-logo">
        <svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <rect width="34" height="34" rx="8" fill="url(#logog1)" style="background:#0F2B46;"/>
          <text x="17" y="23" text-anchor="middle" font-family="Inter" font-size="18" font-weight="800" fill="white">H</text>
        </svg>
        <span class="logo-text">
          <span style="font-weight:400;color:#0F2B46;">human</span>
          <span style="font-weight:800;color:#C9A96E;">AI</span>
          <span style="font-weight:300;color:#8A8A8A;">fit</span>
        </span>
      </a>
      <ul class="nav-links">
        <li><a href={isCn ? '/' : '/en/'} class="nav-home">{isCn ? '首页' : 'Home'}</a></li>
        <li><a href={isCn ? '/services/' : '/en/services/'} class="nav-services">{isCn ? '服务' : 'Services'}</a></li>
        <li><a href={isCn ? '/about/' : '/en/about/'} class="nav-about">{isCn ? '关于' : 'About'}</a></li>
        <li><a href={isCn ? '/policy-tables/' : '/en/policy-tables/'} class="nav-tables">{isCn ? '政策表' : 'Policy Tables'}</a></li>
        <li><a href={isCn ? '/blog/' : '/en/blog/'} class="nav-insights">{isCn ? '洞察' : 'Insights'}</a></li>
        <li><a href="https://cbam.humanaifit.com" class="btn btn-cbam" target="_blank">{isCn ? 'CBAM助手' : 'CBAM Tool'}</a></li>
        <li><a href={isCn ? '/contact/' : '/en/contact/'} class="btn btn-primary" style="padding:8px 20px;font-size:13px;">{isCn ? '合作咨询' : 'Contact'}</a></li>
        <li>
          <!-- Language switch as direct links (no JS dependency) -->
          <a href={isCn ? '/en/' : '/'} class="lang-switch" style="text-decoration:none;cursor:pointer;">{isCn ? 'EN' : '中文'}</a>
        </li>
      </ul>
    </nav>
  </header>

  <main style="padding-top:64px;">
    <slot />
  </main>

  <!-- Footer (v2: 加大Logo + 订阅区 + 社交链接占位) -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="company" style="font-size:28px;margin-bottom:12px;">
            <span style="font-weight:400;color:var(--color-primary);">human</span>
            <span style="color:#C9A96E;font-weight:800;">AI</span>
            <span style="font-weight:300;color:var(--color-text-muted);">fit</span>
          </div>
          <div style="font-size:14px;color:var(--color-text-secondary);margin-bottom:8px;">{isCn ? '彼恳企业管理咨询（上海）有限责任公司' : 'Beacon Consulting Co., Ltd.'}</div>
          <div style="font-size:13px;color:var(--color-text-muted);line-height:1.7;max-width:280px;">
            {isCn
              ? '组织及个人真正的竞争力不来自AI本身，而来自人类智能与人工智能的协同增长。'
              : 'True competitiveness does not come from AI alone, but from the synergy between human intelligence and artificial intelligence.'}
          </div>
          <!-- Social links placeholder -->
          <div style="margin-top:var(--spacing-md);display:flex;gap:12px;">
            <span style="font-size:20px;color:var(--color-text-muted);cursor:default;" title="WeChat">💬</span>
            <span style="font-size:20px;color:var(--color-text-muted);cursor:default;" title="LinkedIn">🔗</span>
            <span style="font-size:20px;color:var(--color-text-muted);cursor:default;" title="Zhihu">📝</span>
          </div>
        </div>
        <div>
          <h4>{isCn ? '服务' : 'Services'}</h4>
          <a href={isCn ? '/services/' : '/en/services/'}>{isCn ? '人机协同咨询' : 'Human-AI Fit Consulting'}</a>
          <a href={isCn ? '/services/' : '/en/services/'}>{isCn ? 'CBAM碳合规' : 'CBAM Carbon Compliance'}</a>
          <a href={isCn ? '/services/' : '/en/services/'}>{isCn ? '全球化战略' : 'Globalization Strategy'}</a>
        </div>
        <div>
          <h4>{isCn ? '联系' : 'Contact'}</h4>
          <a href={isCn ? '/contact/' : '/en/contact/'}>{isCn ? '合作咨询' : 'Get in Touch'}</a>
          <a href={isCn ? '/blog/' : '/en/blog/'}>{isCn ? '行业洞察' : 'Insights'}</a>
        </div>
        <!-- Newsletter subscribe section -->
        <div>
          <h4>{isCn ? '订阅更新' : 'Subscribe'}</h4>
          <p style="font-size:13px;color:var(--color-text-muted);margin-bottom:var(--spacing-sm);">
            {isCn ? '每周精选洞察，直接到你的邮箱。' : 'Weekly insights delivered to your inbox.'}
          </p>
          <form style="display:flex;gap:6px;" action="#" method="post" onsubmit="alert('订阅功能即将上线');return false;">
            <input type="email" placeholder={isCn ? '输入邮箱' : 'your@email.com'} required style="flex:1;padding:8px 12px;border:1px solid var(--color-border);border-radius:6px;font-size:13px;background:var(--color-bg);" />
            <button type="submit" style="padding:8px 16px;background:#3B82F6;color:white;border:none;border-radius:6px;font-size:13px;cursor:pointer;">{isCn ? '订阅' : '→'}</button>
          </form>
        </div>
      </div>
      <div class="footer-bottom">
        &copy; {new Date().getFullYear()} {isCn ? '彼恳企业管理咨询（上海）有限责任公司' : 'Beacon Consulting Co., Ltd.'} — {isCn ? 'All rights reserved.' : 'All rights reserved.'}
      </div>
    </div>
  </footer>
</body>
</html>
