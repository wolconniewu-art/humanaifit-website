  { date: "2026-05-04", slug: "retraining_workers_ai_2026", title: "AI时代的劳动者再培训：从\"替代焦虑\"到\"技能升级\"", tags: "人机契合, 劳动力转型" },
  { date: "2026-05-04", slug: "us_semiconductor_export_controls_2026", title: "美国半导体出口管制2026：规则升级与边界", tags: "全球化, 前沿科技" },
  { date: "2026-05-04", slug: "eu_ai_act_reality_2026", title: "EU AI Act的实施延迟：合规压力退潮还是风暴前的平静？", tags: "人机契合, AI治理" },
  { date: "2026-05-04", slug: "meta_consumer_ai_2026", title: "Meta消费者AI：AI从\"工具\"走向\"日常伴侣\"", tags: "前沿科技, AI应用" },
  { date: "2026-05-03", slug: "CBAM_China_exporters", title: "CBAM碳关税正式生效——中国出口企业绕不开的一课", tags: "全球化, 经济" },
  { date: "2026-05-03", slug: "Deloitte_AI_enterprise_2026", title: "Deloitte 2026报告：企业的AI部署正在加速，但治理在\"掉队\"", tags: "人机契合, 前沿科技" },
  { date: "2026-05-03", slug: "Stanford_AI_Index_2026", title: "Stanford 2026 AI指数：中美AI差距真的在缩小吗？", tags: "全球化, 人机契合" },
  { date: "2026-05-03", slug: "AI_knowledge_management_2026", title: "AI知识管理2026：当知识库变成AI的\"上下文\"", tags: "知识管理, 人机契合" },
  { date: "2026-05-03", slug: "humanoid_robot_half_marathon", title: "人形机器人跑赢人类半马——这意味着什么？", tags: "前沿科技" },
  { date: "2026-05-03", slug: "MERICS_China_humanoid_path", title: "两种路径，一个目标——MERICS报告解读中美机器人产业路线", tags: "全球化, 前沿科技" },
  { date: "2026-05-03", slug: "humanoid_supply_chain_China", title: "人形机器人供应链：中国的\"十亿美元级\"机遇与瓶颈", tags: "前沿科技, 全球化" },
  { date: "2026-05-03", slug: "human_AI_workforce_China", title: "\"人机劳动力\"崛起——中国如何在全球AI劳动力转型中定位自己", tags: "人机契合, 全球化" },
  { date: "2026-05-03", slug: "Australia_AI_moment_China", title: "澳大利亚的\"AI时刻\"：中国在亚太算力竞赛中的站位", tags: "全球化, 前沿科技" },
