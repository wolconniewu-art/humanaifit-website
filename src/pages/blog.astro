  { date: "2026-05-09", slug: "ai_anxiety_three_steps_2026", title: "AI焦虑正在蔓延：该害怕被取代，还是主动进化？", tags: "人机契合, 个人成长" },
  { date: "2026-05-09", slug: "europe_market_china_companies_2026", title: "中国企业出海，欧洲还是不是好市场？——2026年5月最新评估", tags: "全球化, 商业" },
  { date: "2026-05-08", slug: "ai_education_future", title: "AI时代，孩子如何教育才能跑赢未来？", tags: "人机契合, AI教育" },
  { date: "2026-05-07", slug: "ai_knowledge_meaning", title: "AI时代学知识还有意义吗？", tags: "人机契合, AI教育" },
  { date: "2026-05-07", slug: "human_competence", title: "AI时代的人类核心竞争力：不是比AI做得好，而是做AI做不了的事", tags: "人机契合, AI与劳动力" },
  { date: "2026-05-07", slug: "uk_vs_eu_cbam", title: "英国CBAM与欧盟CBAM的区别——一文看懂两个碳边境调节机制", tags: "碳合规, 全球化" },
  { date: "2026-05-07", slug: "carbon_price", title: "一块碳到底能卖多少钱——解密碳定价的底层逻辑", tags: "碳合规, 经济" },
  { date: "2026-05-06", slug: "mckinsey_rigor_ai_impact_2026", title: "从雄心到影响力：麦肯锡最新研究教你用\"严谨\"和\"数据\"把AI落地变真金白银", tags: "人机契合, 商业, 前沿科技" },
  { date: "2026-05-05", slug: "digital_tech_reshape_collaboration", title: "当数字技术重塑人类协作方式，管理学的边界正在被重写", tags: "学术前沿, 人机契合, 组织行为" },
  { date: "2026-05-04", slug: "chinese_evs_tesla_2026", title: "中国电动车出海：从\"价格优势\"到\"价值重构\"", tags: "全球化, 新能源汽车" },
  { date: "2026-05-04", slug: "deepseek_flagship_2026", title: "DeepSeek V4发布：AI赛道的阶段性突破", tags: "前沿科技, 人工智能" },
  { date: "2026-05-04", slug: "deloitte_human_capital_2026", title: "Deloitte 2026人力资本趋势：AI时代的\"文化负债\"", tags: "人机契合, 组织变革" },
