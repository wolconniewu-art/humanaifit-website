<script is:inline>
// ===== 10道题数据 =====
const QUESTIONS = [
  {
    id: 1,
    title: '孩子多大？',
    options: [
      { text: '6-9岁（小学低年级）', scores: { explore: 0, apply: 0, create: 0 }, ageGroup: '6-9' },
      { text: '10-12岁（小学高年级）', scores: { explore: 0, apply: 0, create: 0 }, ageGroup: '10-12' },
      { text: '13-18岁（初中/高中）', scores: { explore: 0, apply: 0, create: 0 }, ageGroup: '13-18' },
    ]
  },
  {
    id: 2,
    title: '孩子拿到一个新工具，一般会？',
    options: [
      { text: '先翻来覆去研究，搞清楚每个按钮干嘛的', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '直接上手用，能达成目的就行', scores: { explore: 0, apply: 2, create: 0 } },
      { text: '不太主动，需要人带着用', scores: { explore: 0, apply: 0, create: 1 } },
    ]
  },
  {
    id: 3,
