  <meta property="og:title" content="孩子AI素养诊断 — 10题测出你孩子的AI学习类型" />
  <meta property="og:description" content="30秒免费诊断，帮你回答「我的孩子该学什么AI？」" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://www.humanaifit.com/diagnosis/" />
  <style>
    :root {
      --primary: #0F2B46;
      --accent: #C9A96E;
      --bg: #f8f7f4;
      --card-bg: #ffffff;
      --text: #2d2d2d;
      --muted: #888888;
      --radius: 12px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      min-height: 100vh;
    }
    .container { max-width: 640px; margin: 0 auto; padding: 20px 16px; }
    
    /* 头部 */
    .header { text-align: center; padding: 32px 0 8px; }
    .header h1 { font-size: 24px; color: var(--primary); font-weight: 700; }
    .header p { font-size: 14px; color: var(--muted); margin-top: 4px; }
    .header .badge {
      display: inline-block;
      background: #e8f5e9;
      color: #2e7d32;
      font-size: 12px;
      padding: 2px 10px;
      border-radius: 20px;
      margin-bottom: 12px;
    }

    /* 进度条 */
    .progress-bar {
      display: flex;
      gap: 4px;
      margin: 24px 0;
    }
    .progress-bar .dot {
      flex: 1;
      height: 4px;
      background: #e0e0e0;
      border-radius: 2px;
      transition: background 0.3s;
    }
    .progress-bar .dot.active { background: var(--accent); }
    .progress-bar .dot.done { background: var(--primary); }

    /* 卡片 */
    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 24px 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
      margin-bottom: 16px;
    }
    .q-number {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 12px;
    }
    .q-title {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 20px;
      line-height: 1.4;
    }

    /* 选项按钮 */
    .options { display: flex; flex-direction: column; gap: 10px; }
    .option {
      display: block;
      width: 100%;
      padding: 14px 16px;
      border: 2px solid #e8e8e8;
      border-radius: 10px;
      background: white;
      font-size: 15px;
      text-align: left;
      cursor: pointer;
      transition: all 0.2s;
      color: var(--text);
      font-family: inherit;
      line-height: 1.4;
    }
    .option:hover { border-color: var(--accent); background: #fefcf5; }
    .option.selected {
      border-color: var(--accent);
      background: #fef8e0;
      font-weight: 500;
    }
    .option:disabled { cursor: not-allowed; opacity: 0.6; }

    /* 按钮 */
    .btn-row { display: flex; gap: 12px; margin-top: 20px; }
    .btn {
      flex: 1;
      padding: 14px;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: inherit;
    }
    .btn-primary {
      background: var(--primary);
      color: white;
    }
    .btn-primary:disabled { background: #ccc; cursor: not-allowed; }
    .btn-primary:hover:not(:disabled) { background: #1a3d5e; }
    .btn-secondary {
      background: transparent;
      color: var(--muted);
      border: 1px solid #ddd;
    }
    .btn-secondary:hover { border-color: var(--accent); color: var(--text); }

    /* 结果页 */
    .result-type {
      font-size: 48px;
      text-align: center;
      margin-bottom: 8px;
    }
    .result-label {
      text-align: center;
      font-size: 22px;
      font-weight: 700;
      color: var(--primary);
      margin-bottom: 4px;
    }
    .result-sub {
      text-align: center;
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 20px;
    }
    .result-section h3 {
      font-size: 15px;
      color: var(--primary);
      margin-bottom: 8px;
      margin-top: 20px;
    }
    .result-section p {
      font-size: 14px;
      color: var(--text);
      line-height: 1.6;
    }
    .result-section ul {
      padding-left: 20px;
      font-size: 14px;
    }
    .result-section li { margin-bottom: 4px; }

    .share-area {
      margin-top: 24px;
      text-align: center;
    }
    .share-area .btn { max-width: 280px; margin: 8px auto; }

    .sep { border: none; border-top: 1px solid #eee; margin: 24px 0; }

    .footer-note {
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      padding: 24px 0;
    }
    .footer-note a { color: var(--primary); text-decoration: none; }

    /* 动画 */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .fade-in { animation: fadeIn 0.3s ease-out; }

    /* 侧边指示 */
    .btn-back { 
      background: none; border: none; 
      color: var(--muted); font-size: 14px; 
      cursor: pointer; padding: 8px 0;
      font-family: inherit;
    }
    .btn-back:hover { color: var(--primary); }

    /* 全屏加载覆盖 */
    .loading-overlay {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(255,255,255,0.85);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 999;
    }
    .loading-spinner {
      width: 32px; height: 32px;
      border: 3px solid #eee;
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }

    @media (max-width: 480px) {
      .container { padding: 16px 12px; }
      .card { padding: 20px 16px; }
      .q-title { font-size: 16px; }
      .option { font-size: 14px; padding: 12px 14px; }
    }
  </style>
  <!-- Structured data for SEO -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
