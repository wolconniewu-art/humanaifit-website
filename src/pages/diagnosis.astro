    options: [
      { text: '自己查资料、翻书、找答案', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '直接找人问（老师/父母/同学）', scores: { explore: 0, apply: 1, create: 0 } },
      { text: '放着不管，除非有人催', scores: { explore: 0, apply: 0, create: 0 } },
    ]
  },
  {
    id: 4,
    title: '孩子对动手做东西的态度是？',
    options: [
      { text: '非常喜欢——做手工、画画、搭积木、写小故事', scores: { explore: 0, apply: 0, create: 2 } },
      { text: '还行——不排斥，但也不会主动', scores: { explore: 0, apply: 2, create: 0 } },
      { text: '不太感兴趣——更喜欢看书或看视频', scores: { explore: 1, apply: 0, create: 0 } },
    ]
  },
  {
    id: 5,
    title: '孩子使用电子设备的情况是？',
    options: [
      { text: '每天主动用，而且会自己探索新功能', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '主要在大人安排下使用（上网课、做作业）', scores: { explore: 0, apply: 1, create: 0 } },
      { text: '尽量限制，接触很少', scores: { explore: 0, apply: 0, create: 0 } },
    ]
  },
