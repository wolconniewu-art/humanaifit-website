    options: [
      { text: '问过，比如"ChatGPT是什么？""AI会取代人类吗？"', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '听说过但没深入问过', scores: { explore: 0, apply: 1, create: 0 } },
      { text: '基本没提过', scores: { explore: 0, apply: 0, create: 0 } },
    ]
  },
  {
    id: 7,
    title: '如果孩子拿到AI工具（如ChatGPT），你觉得他/她会？',
    options: [
      { text: '乱试各种问题，看看它能干嘛', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '在大人引导下用，解决具体问题', scores: { explore: 0, apply: 2, create: 0 } },
      { text: '不知道怎么用，或不太感兴趣', scores: { explore: 0, apply: 0, create: 0 } },
    ]
  },
  {
    id: 8,
    title: '你希望孩子通过AI学习获得什么？（选最优先的一项）',
    options: [
      { text: '保持好奇心和探索能力', scores: { explore: 2, apply: 0, create: 0 } },
      { text: '掌握实用工具，提升学习效率', scores: { explore: 0, apply: 2, create: 0 } },
      { text: '培养创造力和表达能力', scores: { explore: 0, apply: 0, create: 2 } },
    ]
  },
  {
    id: 9,
    title: '你平时对孩子使用科技产品的态度是？',
    options: [
      { text: '开放但有规则——用可以，但要约定时间', scores: { explore: 0, apply: 0, create: 0 } },
      { text: '比较谨慎——能不碰就不碰', scores: { explore: 0, apply: 0, create: 0 } },
      { text: '中立——随他用，反正也管不住', scores: { explore: 0, apply: 0, create: 0 } },
    ]
  },
  {
    id: 10,
    title: '如果现在有一个免费的AI学习路线图，你最想解决的问题是什么？',
    options: [
      { text: '"我不懂AI，不知道怎么引导孩子"', scores: { explore: 1, apply: 0, create: 0 } },
      { text: '"孩子已经在接触AI，我想让她学得更系统"', scores: { explore: 0, apply: 1, create: 0 } },
      { text: '"孩子对AI没兴趣，我想看看有没有必要推"', scores: { explore: 0, apply: 0, create: 1 } },
    ]
  }
];

// ===== 结果模板 =====
const RESULTS = {
  explore: {
    icon: '\uD83D\uDD0D',
    label: '探索型',
    badge: '好奇心驱动',
    desc: '这个小发明家对世界充满好奇\u2014\u2014TA总是想知道"为什么"和"如果\u2026\u2026会怎样"。',
    direction: 'AI工作原理科普、与ChatGPT对话实验、AI伦理小讨论',
    ageAdvice: {
      '6-9': 'AI故事 + AI小实验 + 简单的因果推理游戏',
      '10-12': 'AI原理科普（机器学习入门）+ 数据可视化小项目',
      '13-18': 'AI伦理讨论 + Python+AI入门 + 未来职业探索',
    },
    service: '我们提供"AI探索者家庭学习计划"，包含AI原理启蒙课程、亲子对话指南和适龄学习路径设计。从孩子的第一个AI实验开始，系统培养科学思维。',
    parentNote: '在AI时代，好奇心是孩子最宝贵的能力。您的角色不是回答所有问题，而是帮孩子找到探索AI的起点。我们可以一起构建这份学习计划。'
  },
  apply: {
    icon: '\uD83D\uDEE0\uFE0F',
    label: '应用型',
    badge: '实用主义导向',
    desc: '这个实用主义者不喜欢空谈\u2014\u2014TA更关心"这个东西能帮我做什么"。',
    direction: 'AI写作辅助、AI绘画工具、AI+学习效率',
    ageAdvice: {
      '6-9': '图形化AI工具 + AI辅助画画/写故事',
      '10-12': 'AI辅助学习工具 + 零代码AI项目入门',
      '13-18': 'AI高效学习技巧 + 项目实践（用AI做个作品）',
    },
    service: '我们提供"AI应用者赋能方案"，包含适龄AI工具清单、学习效能提升指南和应用型项目模板。帮孩子从"会用AI"到"用AI解决问题"。',
    parentNote: '您已经看到了AI作为实用工具的价值。接下来可以帮孩子聚焦一个具体问题，用AI去解决它。我们的方案可以帮您和孩子找到最合适的路径。'
  },
  create: {
    icon: '\uD83C\uDFA8',
    label: '创作型',
    badge: '表达者冲动',
    desc: '这个小创作者有表达的冲动\u2014\u2014TA需要的是工具，让想法变成作品。',
    direction: 'AI音乐创作、AI视频制作、AI绘本/故事生成',
    ageAdvice: {
      '6-9': 'AI绘画 + AI绘本制作 + 简单AI音乐创作',
      '10-12': 'AI视频入门 + AI音乐制作 + 数字艺术创作',
      '13-18': '完整创作项目 + 专业工具链 + 作品集搭建指导',
    },
    service: '我们提供"AI创作者成长计划"，包括AI创作工具入门指导、从想法到作品的项目流程和作品集打造建议。让孩子的表达力在AI时代充分释放。',
    parentNote: '创作是孩子理解世界的方式。AI可以帮孩子跨越技术门槛，把脑洞变成真正的作品。我们的计划能帮您为孩子找到合适的创作起点。'
  }
};

// ===== 状态 =====
let currentStep = 0;
let answers = {};
let result = null;

// ===== DOM引用 =====
const cardArea = document.getElementById('cardArea');
const progressBar = document.getElementById('progressBar');
const loadingOverlay = document.getElementById('loadingOverlay');

// ===== 渲染 =====

function renderProgress() {
  progressBar.innerHTML = QUESTIONS.map((q, i) => {
    let cls = 'dot';
    if (i < currentStep) cls += ' done';
    else if (i === currentStep) cls += ' active';
    return `<div class="${cls}"></div>`;
  }).join('');
}

function renderQuestion(step) {
  if (step >= QUESTIONS.length) {
    showResult();
    return;
  }
  const q = QUESTIONS[step];
  const selected = answers[q.id];

  renderProgress();

  cardArea.innerHTML = `
    <div class="card fade-in">
      <div class="q-number">第 ${step + 1} / 10 题</div>
      <div class="q-title">${q.title}</div>
      <div class="options">
        ${q.options.map((opt, i) => `
          <button class="option ${selected === i ? 'selected' : ''}" 
                  data-opt-index="${i}"
                  onclick="selectOption(${step}, ${i})">
            ${opt.text}
          </button>
        `).join('')}
      </div>
      <div class="btn-row">
        ${step > 0 ? '<button class="btn btn-secondary" onclick="prevStep()">\u2190 上一题</button>' : '<div></div>'}
        <button class="btn btn-primary" id="nextBtn" ${selected === undefined ? 'disabled' : ''} 
                onclick="nextStep()">
          ${step < QUESTIONS.length - 1 ? '下一步 \u2192' : '\uD83D\uDCCA 查看结果'}
        </button>
      </div>
    </div>
  `;
}

// ===== 逻辑 =====

function selectOption(step, optIndex) {
  const q = QUESTIONS[step];
  answers[q.id] = optIndex;

  // 更新按钮选中状态
  document.querySelectorAll('.option').forEach((btn, i) => {
    btn.classList.toggle('selected', i === optIndex);
  });

  // 启用下一步按钮
  document.getElementById('nextBtn').disabled = false;
}

function nextStep() {
  if (currentStep < QUESTIONS.length - 1) {
    currentStep++;
    renderQuestion(currentStep);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } else {
    calculateResult();
  }
}

function prevStep() {
  if (currentStep > 0) {
    currentStep--;
    renderQuestion(currentStep);
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
}

function calculateResult() {
  loadingOverlay.classList.remove('hidden');

  let scores = { explore: 0, apply: 0, create: 0 };
  let ageGroup = '10-12';

  QUESTIONS.forEach((q, i) => {
    const ansIdx = answers[q.id];
    if (ansIdx === undefined) return;
    const opt = q.options[ansIdx];
    if (opt.ageGroup) ageGroup = opt.ageGroup;
    scores.explore += (opt.scores.explore || 0);
    scores.apply += (opt.scores.apply || 0);
    scores.create += (opt.scores.create || 0);
  });

  // 判定类型
  let type;
  if (scores.explore >= scores.apply && scores.explore >= scores.create) type = 'explore';
  else if (scores.apply >= scores.create) type = 'apply';
  else type = 'create';

  result = { type, ageGroup, scores };

  setTimeout(() => {
    loadingOverlay.classList.add('hidden');
    renderResult();
  }, 400);
}

function renderResult() {
  const r = RESULTS[result.type];
  const ageKey = result.ageGroup;
  const ageAdviceText = r.ageAdvice[ageKey] || r.ageAdvice['10-12'];
  const ageLabel = { '6-9': '6-9岁', '10-12': '10-12岁', '13-18': '13-18岁' }[ageKey] || '10-12岁';

  progressBar.innerHTML = QUESTIONS.map(() => `<div class="dot done"></div>`).join('');

  cardArea.innerHTML = `
    <div class="card fade-in" style="text-align:left;">
      <div class="result-type">${r.icon}</div>
      <div class="result-label">${r.label}</div>
      <div class="result-sub">${r.badge} \u00B7 ${ageLabel}</div>

      <hr class="sep" />

      <div class="result-section">
        <h3>你的孩子</h3>
        <p>${r.desc}</p>
      </div>

      <div class="result-section">
        <h3>适合学习方向</h3>
        <p>${r.direction}</p>
      </div>

      <div class="result-section">
        <h3>${ageLabel} 学习建议</h3>
        <p>${ageAdviceText}</p>
      </div>

      <div class="result-section" style="margin-top:8px;">
        <h3>为孩子选一个适合的AI学习方案</h3>

        <div style="border:1px solid #e0e0e0;border-radius:10px;padding:14px;margin-bottom:10px;background:#f9fafb;">
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <div>
              <span style="font-weight:600;font-size:15px;">AI素养深度解读报告</span>
              <span style="display:inline-block;margin-left:8px;padding:1px 8px;background:#e8f5e9;color:#2e7d32;border-radius:10px;font-size:11px;">永久有效</span>
            </div>
            <span style="font-weight:700;color:#0F2B46;font-size:16px;">¥49</span>
          </div>
          <p style="font-size:13px;color:#666;margin:6px 0 0;">基于诊断结果生成的10页专属报告，含学习路径推荐和适龄工具清单</p>
        </div>

