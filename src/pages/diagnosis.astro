// ===== 分享 =====
function shareResult() {
  if (typeof html2canvas !== 'undefined') {
    html2canvas(document.querySelector('.card')).then(canvas => {
      const link = document.createElement('a');
      link.download = 'AI素养诊断_${result.type}.png';
      link.href = canvas.toDataURL();
      link.click();
    });
  } else {
    // 不支持截图的降级方案
    const text = [
      '我的孩子是' + RESULTS[result.type].icon + RESULTS[result.type].label + '型！',
      '',
      '30秒免费诊断，测测你家孩子是哪种AI学习者',
      'https://www.humanaifit.com/diagnosis/'
    ].join('\n');

    if (navigator.share) {
      navigator.share({ title: '孩子AI素养诊断', text });
    } else {
      // 复制到剪贴板
      navigator.clipboard.writeText(text).then(() => {
        alert('已复制分享文案，去朋友圈粘贴吧！');
      }).catch(() => {
        alert('请截图分享！');
      });
    }
  }
}

function restart() {
  currentStep = 0;
  answers = {};
  result = null;
  renderQuestion(0);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ===== 键盘支持 =====
document.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    const nextBtn = document.getElementById('nextBtn');
    if (nextBtn && !nextBtn.disabled) nextBtn.click();
  }
  // 数字键 1-3 快速选
  if (['1','2','3'].includes(e.key)) {
    const opts = document.querySelectorAll('.option');
    const idx = parseInt(e.key) - 1;
    if (opts[idx]) opts[idx].click();
  }
});

// ===== 启动 =====
renderQuestion(0);
</script>

