---
import Base from '../../layouts/Base.astro';
---

<Base
  title="About"
  description="About Beacon Consulting — founder Connie and the core team."
  lang="en"
  path="/en/about/"
>
  <section class="section" style="padding-top:100px;">
    <div class="container">
      <p class="section-label">About</p>
      <h1>Beacon Consulting</h1>
      <p style="font-size:17px;max-width:650px;color:var(--color-text-secondary);">
        A new kind of consultancy — grounded in Human-AI Fit research, delivered through real-world practice.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container grid-2" style="align-items:start;">
      <div>
        <h2 style="font-size:1.3rem;margin-bottom:var(--spacing-md);">The Name</h2>
        <p style="color:var(--color-text-secondary);">
          Beacon — a lighthouse. In an era where everyone is "using AI" but few are genuinely growing stronger because of it, we aim to be a beacon, guiding organizations and individuals toward true human-AI synergy.
        </p>
        <p style="color:var(--color-text-secondary);">
          The Chinese name <strong>彼恳</strong> (Bǐ Kěn) is a phonetic translation of Beacon. The domain <strong>humanaifit.com</strong> directly expresses our core research focus.
        </p>

        <h2 style="font-size:1.3rem;margin:var(--spacing-xl) 0 var(--spacing-md);">Founder</h2>
        <p style="color:var(--color-text-secondary);">
          Connie — Researcher, knowledge entrepreneur, human-AI architect.
        </p>
        <p style="color:var(--color-text-secondary);">
          Specializing in Human-AI Fit, enterprise globalization, and knowledge management. Combining academic rigor with industry experience to design sustainable human-AI capability systems.
        </p>

        <h2 style="font-size:1.3rem;margin:var(--spacing-xl) 0 var(--spacing-md);">Our Team</h2>
        <p style="color:var(--color-text-secondary);">
          A "human + AI" hybrid team. Beyond our founder, the core team includes specialized AI Agents:
        </p>
        <ul style="list-style:none;padding:0;color:var(--color-text-secondary);font-size:14px;">
          <li style="padding:8px 0;border-bottom:1px solid var(--color-border);">🌍 Globalization Researcher — China enterprise globalization & academic writing</li>
          <li style="padding:8px 0;border-bottom:1px solid var(--color-border);">🤝 Human-AI Fit Researcher — interdisciplinary theory & compliance writing</li>
          <li style="padding:8px 0;border-bottom:1px solid var(--color-border);">📚 Knowledge Coach — knowledge distillation, case study & competitive analysis</li>
          <li style="padding:8px 0;border-bottom:1px solid var(--color-border);">🌿 CBAM Carbon Assistant — 30-second self-check for EU carbon tariff impact</li>
          <li style="padding:8px 0;">🔧 More specialized AI Agents coming soon…</li>
        </ul>
      </div>
      <div style="padding:var(--spacing-xl);background:var(--color-primary);color:white;border-radius:8px;">
        <p class="section-label" style="color:var(--color-accent);">Core Belief</p>
        <blockquote style="font-size:18px;font-style:normal;line-height:1.7;margin:var(--spacing-lg) 0;border-left:3px solid var(--color-accent);padding-left:var(--spacing-lg);">
          True competitive strength does not come from AI alone,<br>
          but from the synergy between human intelligence and artificial intelligence.
        </blockquote>
        <p style="font-size:13px;opacity:0.7;margin-top:var(--spacing-xl);">— We live this conviction every day.</p>
      </div>
    </div>
  </section>

  <section class="section section-dark text-center">
    <div class="container">
      <h2>Want to Talk?</h2>
      <p style="max-width:500px;margin:var(--spacing-md) auto var(--spacing-xl);opacity:0.85;font-size:15px;">
        Whether you're optimizing AI use in your organization or preparing for CBAM, we'd love to listen.
      </p>
      <a href="/en/contact/" class="btn btn-primary">Contact Us →</a>
    </div>
  </section>
</Base>
