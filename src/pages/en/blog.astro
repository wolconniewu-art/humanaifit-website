---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Insights"
  description="Frontier thinking on Human-AI Fit, carbon compliance, globalization and knowledge management."
  lang="en"
  path="/en/blog/"
>
  <section class="section" style="padding-top:100px;">
    <div class="container text-center">
      <p class="section-label">Insights</p>
      <h1>Thinking at the Frontier</h1>
      <p style="max-width:600px;margin:var(--spacing-md) auto 0;color:var(--color-text-secondary);">
        Deep dives on Human-AI Fit, carbon compliance, globalization and knowledge management. Coming soon.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container text-center" style="padding:var(--spacing-3xl) 0;">
      <div style="font-size:48px;margin-bottom:var(--spacing-lg);">📝</div>
      <h3>Content Coming Soon</h3>
      <p style="color:var(--color-text-secondary);max-width:400px;margin:var(--spacing-md) auto;">
        Our research team is working on a series of in-depth articles covering Human-AI Fit, CBAM compliance, enterprise globalization and more.
      </p>
      <p style="color:var(--color-text-muted);font-size:13px;">Stay tuned</p>
    </div>
  </section>

  <section class="section section-dark text-center">
    <div class="container">
      <h2>Don't Want to Miss Updates?</h2>
      <p style="max-width:500px;margin:var(--spacing-md) auto var(--spacing-xl);opacity:0.85;font-size:15px;">
        Leave your contact and we'll notify you when new articles are published.
      </p>
      <a href="/en/contact/" class="btn btn-primary">Subscribe →</a>
    </div>
  </section>
</Base>
