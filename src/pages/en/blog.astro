  { date: "2026-05-03", slug: "ai_anxiety_three_steps_2026", title: "AI Anxiety Is Spreading", tags: "Human-AI Fit, Personal Growth" },
  { date: "2026-05-03", slug: "europe_market_china_companies_2026", title: "Chinese Companies in Europe — May 2026", tags: "Globalization, Business" },
  { date: "2026-05-02", slug: "global_localization", title: 'From Mixue to NIO: The "Localization Paradox" of Chinese Global Brands', tags: "Globalization, Business" },
  { date: "2026-05-02", slug: "digital_leadership", title: "When AI Can Replace 70% of Management, Where Is the Leader's Value?", tags: "Human-AI Fit, Business" },
  { date: "2026-05-02", slug: "AI_productivity_paradox", title: "When AI Investment Shows No Results — A Deep Dive into the Productivity Paradox", tags: "Human-AI Fit, Knowledge Management" },
  { date: "2026-05-02", slug: "behavioral_economics_human_ai", title: "When Automation Bias Meets Algorithm Aversion: Human-AI Collaboration Through Behavioral Economics", tags: "Human-AI Fit, Tech Frontiers" },
