---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Insights"
  description="Frontier thinking on Human-AI Fit, carbon compliance, globalization and knowledge management."
  lang="en"
  path="/en/blog/"
>
  <section class="section" style="padding-top:100px;">
    <div class="container">
      <p class="section-label">Insights</p>
      <h1>Thinking at the Frontier</h1>
      <p style="max-width:600px;margin:var(--spacing-md) auto 0;color:var(--color-text-secondary);">
        Deep dives on Human-AI Fit, carbon compliance, globalization and knowledge management.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0;">
    <div class="container">

      <!-- 2026-05-07: 4 new articles -->
      <div style="margin-bottom:var(--spacing-lg);border-bottom:1px solid var(--color-border);padding-bottom:var(--spacing-sm);">
        <p style="font-size:12px;color:var(--color-text-muted);margin-bottom:var(--spacing-xs);">May 2026</p>
        <div style="padding:var(--spacing-md) 0;">
          <span style="background:rgba(201,169,110,0.1);color:var(--color-accent-dark);padding:2px 8px;border-radius:12px;font-size:11px;">Carbon Compliance</span>
          <span style="background:rgba(15,43,70,0.05);color:var(--color-text-secondary);padding:2px 8px;border-radius:12px;font-size:11px;margin-left:6px;">Economics</span>
        </div>
        <h3 style="font-size:1rem;line-height:1.4;"><a href="/en/blog/carbon_price/" style="color:var(--color-primary);text-decoration:none;">What Is a Ton of Carbon Actually Worth?</a></h3>
        <p style="color:var(--color-text-secondary);font-size:13px;margin-top:6px;">
          Breaking down the carbon pricing mechanism — from EU ETS to China's national carbon market.
        </p>
        <p style="font-size:12px;color:var(--color-text-muted);margin-top:4px;">2026-05-07</p>
      </div>

      <div style="margin-bottom:var(--spacing-lg);border-bottom:1px solid var(--color-border);padding-bottom:var(--spacing-sm);">
        <p style="font-size:12px;color:var(--color-text-muted);margin-bottom:var(--spacing-xs);">May 2026</p>
        <div style="padding:var(--spacing-md) 0;">
          <span style="background:rgba(201,169,110,0.1);color:var(--color-accent-dark);padding:2px 8px;border-radius:12px;font-size:11px;">Carbon Compliance</span>
          <span style="background:rgba(15,43,70,0.05);color:var(--color-text-secondary);padding:2px 8px;border-radius:12px;font-size:11px;margin-left:6px;">Globalization</span>
        </div>
        <h3 style="font-size:1rem;line-height:1.4;"><a href="/en/blog/uk_vs_eu_cbam/" style="color:var(--color-primary);text-decoration:none;">UK CBAM vs EU CBAM: Key Differences Explained</a></h3>
        <p style="color:var(--color-text-secondary);font-size:13px;margin-top:6px;">
          A clear comparison of the EU and UK carbon border adjustment mechanisms.
        </p>
        <p style="font-size:12px;color:var(--color-text-muted);margin-top:4px;">2026-05-07</p>
      </div>

      <div style="margin-bottom:var(--spacing-lg);border-bottom:1px solid var(--color-border);padding-bottom:var(--spacing-sm);">
        <p style="font-size:12px;color:var(--color-text-muted);margin-bottom:var(--spacing-xs);">May 2026</p>
        <div style="padding:var(--spacing-md) 0;">
          <span style="background:rgba(201,169,110,0.1);color:var(--color-accent-dark);padding:2px 8px;border-radius:12px;font-size:11px;">Human-AI Fit</span>
