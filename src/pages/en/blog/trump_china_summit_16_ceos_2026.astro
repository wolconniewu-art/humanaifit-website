      <h1 style="font-size:2rem;line-height:1.35;">When 16 US CEOs Flew to Beijing: Trump's China Summit and the 'Multi-Polar Co-opetition' Moment</h1>
      <div class="article-meta">
        <span>2026-05-14</span>
        {tags.filter(Boolean).map(t => <span class="tag">{t}</span>)}
