      <h1 style="font-size:2rem;line-height:1.35;">UK CBAM vs EU CBAM: Key Differences Explained</h1>
      <div class="article-meta">
        <span>2026-05-07</span>
        {tags.filter(Boolean).map(t => <span class="tag">{t}</span>)}
      </div>
    </div>
