---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Human-AI Synergy"
  description="Beacon Consulting — focused on Human-AI Fit research and practice, helping organizations achieve true competitive growth."
  lang="en"
  path="/en/"
>
  <!-- Hero -->
  <section class="section" style="padding-top:100px;padding-bottom:80px;">
    <div class="container text-center">
      <div class="fade-in" style="margin-bottom:var(--spacing-lg);">
        <!-- Logo large -->
        <svg width="440" height="100" viewBox="0 0 440 100" style="margin:0 auto;" xmlns="http://www.w3.org/2000/svg">
          <text x="20" y="50" font-family="Inter, sans-serif" font-size="42" font-weight="200" fill="#0F2B46">&lt;</text>
          <text x="62" y="50" font-family="Inter, sans-serif" font-size="42" font-weight="200" fill="#0F2B46">/</text>
          <text x="96" y="50" font-family="Inter, sans-serif" font-size="42" font-weight="800" fill="#C9A96E">AI</text>
          <text x="20" y="80" font-family="Inter, sans-serif" font-size="22" font-weight="600" fill="#0F2B46" letter-spacing="-0.5">human</text>
          <text x="107" y="80" font-family="Inter, sans-serif" font-size="22" font-weight="800" fill="#C9A96E" letter-spacing="-0.5">ai</text>
          <text x="150" y="80" font-family="Inter, sans-serif" font-size="22" font-weight="300" fill="#0F2B46" letter-spacing="-0.5">fit</text>
        </svg>
      </div>
      <p class="section-label">Beacon Consulting Co., Ltd.</p>
      <h1 style="max-width:700px;margin:0 auto var(--spacing-lg);">
        You've adopted AI.<br>
        Has your competitiveness grown?
      </h1>
      <p style="font-size:18px;color:var(--color-text-secondary);max-width:600px;margin:0 auto var(--spacing-xl);line-height:1.8;">
        We specialize in <span style="font-weight:600;color:var(--color-primary);">Human-AI Fit</span> —
        helping organizations move from "using AI" to a state where human and AI capabilities compound each other.
      </p>
      <div style="display:flex;gap:var(--spacing-md);justify-content:center;flex-wrap:wrap;">
        <a href="/en/contact/" class="btn btn-primary">Free Consultation →</a>
        <a href="/en/services/" class="btn btn-outline">Our Services</a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container">
      <div class="text-center" style="margin-bottom:var(--spacing-3xl);">
        <p class="section-label">Our Belief</p>
        <h2>True Competitiveness Comes from Human-AI Synergy</h2>
        <p style="font-size:18px;color:var(--color-text-secondary);max-width:600px;margin:var(--spacing-md) auto 0;">
          Not the AI tool itself, but how humans and AI work together, determines who leads through change.
        </p>
      </div>

      <div class="grid-3">
        <div style="padding:var(--spacing-xl);background:var(--color-bg);border-radius:8px;border:1px solid var(--color-border);">
          <div style="font-size:32px;margin-bottom:var(--spacing-md);color:var(--color-accent);">01</div>
          <h4>Human-AI Fit</h4>
          <p style="font-size:14px;color:var(--color-text-secondary);">Diagnose your organization's AI maturity, design human-AI collaborative workflows, and turn tech investments into real productivity.</p>
        </div>
        <div style="padding:var(--spacing-xl);background:var(--color-bg);border-radius:8px;border:1px solid var(--color-border);">
          <div style="font-size:32px;margin-bottom:var(--spacing-md);color:var(--color-accent);">02</div>
          <h4>CBAM Compliance</h4>
          <p style="font-size:14px;color:var(--color-text-secondary);">Self-check your products in 30 seconds. Low-cost carbon compliance for SMEs navigating EU CBAM regulations.</p>
        </div>
        <div style="padding:var(--spacing-xl);background:var(--color-bg);border-radius:8px;border:1px solid var(--color-border);">
          <div style="font-size:32px;margin-bottom:var(--spacing-md);color:var(--color-accent);">03</div>
          <h4>Globalization Strategy</h4>
          <p style="font-size:14px;color:var(--color-text-secondary);">Academic research meets industry practice. Market entry, compliance pathways, and localization for Chinese enterprises going global.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CBAM CTA -->
  <section class="section section-dark text-center">
    <div class="container">
      <p class="section-label">Free Tool</p>
      <h2 style="font-size:1.8rem;">CBAM Carbon Compliance Checker</h2>
      <p style="max-width:500px;margin:var(--spacing-md) auto var(--spacing-xl);font-size:15px;opacity:0.85;">
        Self-check if your products fall under EU CBAM regulations. Free, no registration required.
      </p>
      <a href="https://cbam.humanaifit.com" class="btn btn-primary" target="_blank">Start Check →</a>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="section">
    <div class="container">
      <div class="grid-2" style="align-items:center;">
        <div>
          <p class="section-label">About</p>
          <h2>Researcher · Entrepreneur ·<br>Human-AI Architect</h2>
          <p style="color:var(--color-text-secondary);">
            Founded by Connie, Beacon Consulting focuses on Human-AI Fit. We don't sell software or templates —
            we bring academic rigor and industry experience to help organizations find their optimal human-AI synergy path.
          </p>
          <p style="color:var(--color-text-secondary);">
            Our core team includes specialized AI Agents (Globalization Researcher, Human-AI Fit Researcher, Knowledge Coach), delivering at a pace and depth traditional consulting cannot match.
          </p>
          <a href="/en/about/" class="btn btn-outline" style="margin-top:var(--spacing-md);">Learn More →</a>
        </div>
        <div style="padding:var(--spacing-xl);background:var(--color-surface);border-radius:8px;border:1px solid var(--color-border);">
          <div style="font-size:13px;color:var(--color-text-muted);margin-bottom:var(--spacing-lg);">Core Competencies</div>
          <div style="display:flex;flex-wrap:wrap;gap:var(--spacing-sm);">
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">Human-AI Fit</span>
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">Organizational Behavior</span>
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">CBAM Compliance</span>
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">Globalization</span>
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">Knowledge Management</span>
            <span style="padding:6px 14px;background:rgba(201,169,110,0.1);color:var(--color-accent-dark);border-radius:20px;font-size:13px;font-weight:500;">AI Collaboration</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Teaser -->
  <section class="section" style="background:var(--color-surface);">
    <div class="container text-center">
      <p class="section-label">Insights</p>
      <h2 style="margin-bottom:var(--spacing-lg);">Thinking at the Frontier</h2>
      <p style="color:var(--color-text-secondary);max-width:500px;margin:0 auto var(--spacing-xl);">
        Deep dives on Human-AI Fit, carbon compliance, globalization, and knowledge management. Coming soon.
      </p>
      <a href="/en/blog/" class="btn btn-outline">Browse Articles</a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section section-dark text-center">
    <div class="container">
      <h2 style="font-size:1.8rem;">Ready to Talk?</h2>
      <p style="max-width:500px;margin:var(--spacing-md) auto var(--spacing-xl);font-size:15px;opacity:0.85;">
        Tell us about your challenge. We'll give you a direction within 30 minutes.
      </p>
      <a href="/en/contact/" class="btn btn-primary">Book Now →</a>
    </div>
  </section>
</Base>
